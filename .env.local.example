# Copy to .env.local and adjust credentials
#
# Dev server LAN access (optional — silences allowedDevOrigins warning):
# ALLOWED_DEV_ORIGINS=172.20.24.10,192.168.1.100
#
# IMPORTANT (Windows + WSL):
# - WSL MySQL and Windows MySQL80 are separate servers on port 3306
# - From Windows PowerShell: npm run dev  (auto-starts in WSL if local DB fails)
# - Or always WSL: npm run dev:wsl
# - Windows-only fix: $env:MYSQL_ROOT_PASSWORD="..." ; node scripts/setup-windows-db-user.mjs
# - Check: npm run db:check
#
# This Next.js app uses goeunserverhub ONLY (DATABASE_URL and DB_NAME must be goeunserverhub).
DATABASE_URL="mysql://geserverhub:YOUR_PASSWORD@localhost:3306/goeunserverhub"
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=goeunserverhub

# Optional: legacy Python site on :8000 (profile/services for homepage only — NOT energy DB).
# Energy /api/kenergy/* never proxies here; all energy data is in goeunserverhub.
BACKEND_URL=http://127.0.0.1:8000

# Energy monitoring: same goeunserverhub database as Prisma. Run: npm run db:setup-energy
KOREA_ELECTRICITY_RATE=140
THAILAND_ELECTRICITY_RATE=3.88

# MQTT bridge (npm run mqtt:bridge) — subscribes telemetry and writes power_records
# Uses mqtt_settings from DB when present; otherwise these env vars:
# MQTT_BRIDGE_HOST=broker.example.com
# MQTT_BRIDGE_PORT=1883
# MQTT_BRIDGE_USER=
# MQTT_BRIDGE_PASS=
# MQTT_BRIDGE_TOPIC=ge/#
# MQTT_BRIDGE_TOPIC_PREFIX=ge
# MQTT_BRIDGE_SITES=thailand,korea

# AI carbon analysis — optional server default OR save token in Dashboard UI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# (UI-saved token in ai_settings overrides .env for logged-in user)
# Carbon credit reference price per tonne CO₂e (by site)
# CARBON_CREDIT_PRICE_THB=250
# CARBON_CREDIT_PRICE_KRW=32000
