# Copy to .env.local and adjust credentials
#
# IMPORTANT (Windows + WSL):
# - WSL MySQL and Windows MySQL80 are separate servers on port 3306
# - From Windows PowerShell: npm run dev  (auto-starts in WSL if local DB fails)
# - Or always WSL: npm run dev:wsl
# - Windows-only fix: $env:MYSQL_ROOT_PASSWORD="..." ; node scripts/setup-windows-db-user.mjs
# - Check: npm run db:check
#
DATABASE_URL="mysql://geserverhub:YOUR_PASSWORD@localhost:3306/geserverhub"
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=geserverhub
BACKEND_URL=http://127.0.0.1:8000
