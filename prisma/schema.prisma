generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clientId      String?

  accounts Account[]
  sessions Session[]
  client   Client?   @relation(fields: [clientId], references: [id])
  invoices Invoice[]

  @@index([email])
  @@index([clientId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id           String   @id @default(cuid())
  name         String
  nameTh       String?
  slug         String   @unique
  description  String?  @db.Text
  status       Status   @default(COMING_SOON)
  contactEmail String?
  contactPhone String?
  contactFax   String?
  address      String?  @db.Text
  systemUrl          String?
  logoUrl            String?
  lineUserId         String?
  domainRegisteredAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt    DateTime @updatedAt

  users    User[]
  services ClientService[]
  invoices Invoice[]
  receipts Receipt[]
  customers Customer[]
  partnerProducts         PartnerProduct[]
  partnerProductCategories PartnerProductCategory[]

  @@index([slug])
  @@index([status])
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  highlight   String
  price       Decimal? @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clients ClientService[]
}

model ClientService {
  clientId   String
  serviceId  String
  assignedAt DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([clientId, serviceId])
  @@index([clientId])
  @@index([serviceId])
}

model Invoice {
  id            String        @id @default(cuid())
  number        String        @unique
  receiptNumber String?       @unique
  clientId      String
  userId    String?
  amount    Decimal       @db.Decimal(10, 2)
  currency  String        @default("THB")
  status    InvoiceStatus @default(PENDING)
  dueDate   DateTime?
  paidAt    DateTime?
  stripeId  String?       @unique
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([clientId])
  @@index([status])
}

model Receipt {
  id        String   @id @default(cuid())
  number    String   @unique
  clientId  String
  customerId      String?
  customerName    String   @default("")
  customerAddress String?  @db.Text
  customerPhone   String?
  customerEmail   String?
  currency  String   @default("THB")
  issuedAt  DateTime @default(now())
  subtotal  Decimal  @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client        @relation(fields: [clientId], references: [id])
  customer Customer?     @relation(fields: [customerId], references: [id])
  items    ReceiptItem[]

  @@index([clientId])
  @@index([customerId])
  @@index([issuedAt])
}

model ReceiptItem {
  id          String   @id @default(cuid())
  receiptId   String
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal @default(0) @db.Decimal(10, 2)
  amount      Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([sortOrder])
}

model Customer {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  phone     String?
  email     String?
  address   String?  @db.Text
  idCard    String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  receipts Receipt[]

  @@index([clientId])
  @@index([name])
}

model Notification {
  id        String              @id @default(cuid())
  type      NotificationType
  channel   NotificationChannel
  recipient String
  subject   String?
  body      String              @db.Text
  sent      Boolean             @default(false)
  sentAt    DateTime?
  error     String?
  createdAt DateTime            @default(now())

  @@index([sent])
  @@index([type])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CLIENT
  PARTNER
}

enum Status {
  ONLINE
  MAINTENANCE
  COMING_SOON
  OFFLINE
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  INVOICE
  SYSTEM_ALERT
  WELCOME
  PASSWORD_RESET
}

model Expense {
  id            String   @id @default(cuid())
  number        String   @unique
  category      String
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("THB")
  status        String   @default("รอชำระ")
  notes         String?  @db.Text
  date          DateTime @default(now())
  receiptNumber String?
  receiptFile   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([date])
}

model Product {
  id             Int      @id @default(autoincrement())
  sku            String   @unique
  category       String
  name           String
  nameEn         String
  nameZh         String
  price          Decimal  @db.Decimal(10, 2)
  priceWholesale Decimal  @db.Decimal(10, 2)
  unit           String
  minOrder       Int      @default(1)
  minWholesale   Int      @default(10)
  desc           String?  @db.Text
  img            String?
  stock          Int      @default(0)
  rating         Decimal  @db.Decimal(3, 1) @default(5.0)
  sold           Int      @default(0)
  active         Boolean  @default(true)
  promotion      String?
  promotionPrice Decimal? @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([active])
}

enum NotificationChannel {
  EMAIL
  LINE
  PUSH
}

model PartnerTask {
  id          String    @id @default(cuid())
  title       String
  type        String    @default("OPERATION") // TAX_FILING | OPERATION | DOCUMENT | OTHER
  status      String    @default("PENDING")   // PENDING | IN_PROGRESS | COMPLETED | CANCELLED
  priority    String    @default("NORMAL")    // LOW | NORMAL | HIGH | URGENT
  brand       String    @default("MOMOGE SPACE")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([dueDate])
}

model PartnerTransaction {
  id           String   @id @default(cuid())
  number       String   @unique
  brand        String   @default("MOMOGE SPACE")
  type         String   @default("SALE") // SALE | EXPENSE | REFUND
  description  String?
  customerName String?
  amount       Decimal  @db.Decimal(14, 2)
  currency     String   @default("KRW")
  status       String   @default("COMPLETED") // COMPLETED | PENDING | CANCELLED
  category     String?
  notes        String?  @db.Text
  receiptFile  String?  @db.Text
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([date])
  @@index([brand])
}

model PartnerProductCategory {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)
  clientId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  products PartnerProduct[]

  @@unique([clientId, name])
  @@index([clientId])
  @@index([sortOrder])
}

model PartnerProduct {
  id         String   @id @default(cuid())
  name       String
  model      String?
  brand      String?
  costPrice  Decimal? @db.Decimal(14, 2)
  sellPrice  Decimal? @db.Decimal(14, 2)
  currency   String   @default("KRW")
  imageUrls  String?  @db.Text
  categoryId String?
  clientId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client   Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  category PartnerProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([clientId])
  @@index([categoryId])
}

model PartnerPersonFinancial {
  id            String   @id @default(cuid())
  personName    String
  ledgerType    String   // PROFIT_SHARE | INVESTMENT
  amount        Decimal  @db.Decimal(14, 2)
  currency      String   @default("KRW")
  transactionId String?  @unique
  recordedAt    DateTime @default(now())
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([personName, ledgerType])
  @@index([recordedAt])
}

model PartnerMonthlyFinancial {
  id            String   @id @default(cuid())
  year          Int
  month         Int
  revenueKrw    Decimal  @default(0) @db.Decimal(14, 2)
  investmentKrw Decimal  @default(0) @db.Decimal(14, 2)
  expenseKrw    Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt     DateTime @updatedAt

  @@unique([year, month])
}

model MFactoryInquiry {
  id            String    @id @default(cuid())
  type          String    @default("factory")
  lang          String    @default("th")
  source        String?
  company       String?
  name          String
  phone         String?
  email         String?
  taxId         String?
  bookingDate   DateTime? @db.Date
  address       String?   @db.Text
  warehouse     String?   @db.Text
  rentalType    String?
  paymentRef    String?
  message       String?   @db.Text
  bookingNumber String?   @unique
  status        String    @default("PENDING")
  termsAccepted Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([createdAt])
  @@index([type])
  @@index([status])
}

model CargoOrder {
  id            String   @id @default(cuid())
  number        String   @unique
  senderName    String
  senderPhone   String?
  receiverName  String
  receiverPhone String?
  receiverAddress String? @db.Text
  direction     String   @default("TH_TO_KR") // "TH_TO_KR" | "KR_TO_TH"
  weightKg      Decimal? @db.Decimal(8, 2)
  sizeNote      String?
  itemDesc      String?  @db.Text
  currency      String   @default("THB")
  income        Decimal  @default(0) @db.Decimal(10, 2)
  expense       Decimal  @default(0) @db.Decimal(10, 2)
  status        String   @default("รับพัสดุแล้ว")
  trackingCode  String?
  passportNo    String?
  imageUrl      String?  @db.Text
  parcelImageUrl String? @db.Text
  notes         String?  @db.Text
  shippedAt     DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([direction])
  @@index([createdAt])
}

model FileConversionJob {
  id                    String                 @id @default(cuid())
  platform              ConversionPlatform
  sourceName            String
  sourcePath            String                 @db.Text
  sourceMime            String
  sourceSize            Int
  sourceExtension       String                 @default(".png")
  sourceSha1            String?
  bundleName            String?
  bundlePath            String?                @db.Text
  bundleMime            String?
  bundleSize            Int?
  bundleExtension       String?
  bundleSha1            String?
  bundleSigningSha1     String?
  storeUploadExtensions String?                @db.Text
  status                ConversionStatus       @default(SUCCESS)
  errorMessage          String?                @db.Text
  createdById           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  results               FileConversionResult[]

  @@index([platform, createdAt])
  @@index([createdById])
}

model FileConversionResult {
  id            String            @id @default(cuid())
  jobId         String
  fileName      String
  filePath      String            @db.Text
  mimeType      String
  fileExtension String            @default(".png")
  sha1          String?
  signingSha1   String?
  fileSize      Int
  width         Int
  height        Int
  target        ConversionTarget
  storeEligible Boolean           @default(true)
  usageNote     String?
  createdAt     DateTime          @default(now())
  job           FileConversionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([target])
  @@index([fileExtension])
}

model FileAppArchiveRecord {
  id            String             @id @default(cuid())
  platform      ConversionPlatform
  fileName      String
  filePath      String             @db.Text
  fileMime      String?
  fileSize      Int
  fileExtension String
  fileSha1      String
  signingSha1   String?
  packageName   String?
  createdById   String?
  createdAt     DateTime           @default(now())

  @@index([platform, createdAt])
  @@index([createdById])
}

enum ConversionPlatform {
  ANDROID
  IOS
}

enum ConversionStatus {
  SUCCESS
  FAILED
}

enum ConversionTarget {
  APP_ICON
  STORE_LISTING
  APP_BUNDLE
}

enum SoftwareDownloadOrderStatus {
  PENDING
  AWAITING_REVIEW
  PAID
  CANCELLED
}

model SoftwareDownloadOrder {
  id                      String                      @id @default(cuid())
  orderCode               String                      @unique
  email                   String
  productSlug             String
  productTitle            String
  amount                  Decimal                     @db.Decimal(10, 2)
  currency                String                      @default("THB")
  status                  SoftwareDownloadOrderStatus @default(PENDING)
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  paymentGateway          String?
  receiptFile             String?
  notes                   String?                     @db.Text
  paidAt                  DateTime?
  downloadCount           Int                         @default(0)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt

  @@index([orderCode])
  @@index([email])
  @@index([status])
  @@index([productSlug])
}
