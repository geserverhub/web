# Public HTTPS hub (defaults to permanent ngrok if unset)
CAPACITOR_SERVER_URL=https://strong-dory-enabled.ngrok-free.app
# CAPACITOR_USE_BUNDLED=1

# Release signing (do not commit real values)
ANDROID_KEYSTORE_PATH=C:/path/to/phone-remote-release.jks
